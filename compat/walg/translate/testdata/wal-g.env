# /etc/default/wal-g — sample env file for the translator test rig
WALG_S3_PREFIX=s3://acme-pg-backups/wal-g
AWS_ENDPOINT=https://s3.eu-central-1.amazonaws.com
AWS_REGION=eu-central-1

PGHOST=db1.example.com
PGPORT=5432
PGUSER=pgbackup
PGDATABASE=postgres

WALG_COMPRESSION_METHOD=lz4
WALG_DELTA_MAX_STEPS=8
WALG_LIBSODIUM_KEY=ABCDEF
WALG_TAR_SIZE_THRESHOLD=1073741824

# Quoted to test the unquoter
WALG_DOWNLOAD_CONCURRENCY="32"
export WALG_UPLOAD_CONCURRENCY=16

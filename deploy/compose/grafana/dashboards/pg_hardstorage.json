{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "pg_hardstorage overview",
  "uid": "pg-hardstorage-overview",
  "tags": ["pg_hardstorage"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Build",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^(version|commit)$/" },
        "textMode": "name",
        "colorMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
          "expr": "pg_hardstorage_build_info",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Backups completed (by result)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
          "expr": "sum by (result) (pg_hardstorage_backup_completed_total)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WAL segments archived",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
          "expr": "sum(pg_hardstorage_wal_segments_archived_total)"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Backups started / completed (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
          "expr": "sum by (deployment) (rate(pg_hardstorage_backup_started_total[5m]))",
          "legendFormat": "started {{deployment}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
          "expr": "sum by (result) (rate(pg_hardstorage_backup_completed_total[5m]))",
          "legendFormat": "completed {{result}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Chunk uploads (rate, by result)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pgh-prometheus" },
          "expr": "sum by (result) (rate(pg_hardstorage_chunk_uploads_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    }
  ]
}

# Maintainer: Hans-Jürgen Schönig <hs@cybertec.at>
# pg_hardstorage — PostgreSQL backup, done right.
#
# This PKGBUILD lives in-tree (not in the AUR) because the
# package builds from a git checkout the operator already has.
# Build via:
#
#   cd packaging/arch
#   makepkg -si
#
# `makepkg` runs from a non-root user; from the project root use
# `makepkg --dir packaging/arch -si`.  The recipe re-runs the
# project's `make build` so the resulting .pkg.tar.zst is
# stamped with the same VERSION/COMMIT/DATE as a from-source
# install.

pkgname=pg-hardstorage
pkgver=0.1.1
pkgrel=1
pkgdesc="PostgreSQL backup, done right — agent and CLI"
arch=('x86_64' 'aarch64')
url="https://github.com/cybertec-postgresql/pg_hardstorage"
license=('Apache-2.0')
depends=('glibc')
optdepends=(
    'postgresql: drives backups against a local PG'
    'systemd: ships a service unit for the long-running agent'
)
makedepends=('go>=1.26' 'make' 'git')
provides=('pg-hardstorage')
conflicts=('pg-hardstorage-bin')
backup=('etc/pg_hardstorage/pg_hardstorage.yaml.example')

# Source: relative path to the project root (three levels up
# from this PKGBUILD).  makepkg's `source=()` accepts local
# paths via `local::file://...` but a directory checkout is
# cleaner — we cp the working tree into ${srcdir} in prepare().
source=()
sha256sums=()

prepare() {
    # Vendor the project root into ${srcdir}/${pkgname}-${pkgver}.
    # Operators running makepkg from a working tree expect their
    # current changes to land in the .pkg.tar.zst — copying via
    # rsync (skipping bin/ + test-runs/) is exactly that.
    local repo_root
    repo_root=$(cd "${startdir}/../.." && pwd)
    local target="${srcdir}/${pkgname}-${pkgver}"
    mkdir -p "${target}"
    # `--exclude='/packaging/arch/src/'` is load-bearing: makepkg
    # places ${srcdir} INSIDE the source tree (default
    # ${startdir}/src), so without this exclude rsync copies its
    # own destination back into itself, recursing into every
    # in-progress copy and ballooning the staging dir into the
    # double-digit-GB range before the disk fills.
    rsync -a \
        --exclude='/bin/' \
        --exclude='/test-runs/' \
        --exclude='/packaging/arch/src/' \
        --exclude='.git/' \
        "${repo_root}/" "${target}/"
}

build() {
    cd "${pkgname}-${pkgver}"
    export CGO_ENABLED=0
    export GOFLAGS="-trimpath -buildvcs=false"
    local commit
    commit=$(cd "${startdir}/../.." && git rev-parse --short HEAD 2>/dev/null || echo none)
    local date_iso
    date_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    make build VERSION="${pkgver}" COMMIT="${commit}" DATE="${date_iso}"
    make build-compat VERSION="${pkgver}" COMMIT="${commit}" DATE="${date_iso}" || true
}

package() {
    cd "${pkgname}-${pkgver}"

    install -Dm755 bin/pg_hardstorage "${pkgdir}/usr/bin/pg_hardstorage"

    # Compat shims — best-effort install.  build-compat is
    # tolerant of missing source trees per shim, and so is the
    # install: a half-merge of one shim doesn't block the
    # primary binary from packaging cleanly.
    for shim in pg-hardstorage-pgbackrest pg-hardstorage-barman \
                pg-hardstorage-barman-wal-archive pg-hardstorage-walg; do
        if [[ -x "bin/${shim}" ]]; then
            install -Dm755 "bin/${shim}" "${pkgdir}/usr/bin/${shim}"
        fi
    done

    # systemd unit.  Arch-style: drop into /usr/lib/systemd/system
    # (NOT /lib/systemd/system — that's Debian-style and Arch
    # symlinks /lib → /usr/lib).
    install -Dm644 deploy/systemd/pg_hardstorage.service \
        "${pkgdir}/usr/lib/systemd/system/pg_hardstorage.service"
    install -Dm644 deploy/systemd/pg_hardstorage@.service \
        "${pkgdir}/usr/lib/systemd/system/pg_hardstorage@.service"
    install -Dm644 deploy/systemd/pg-hardstorage.sysusers.conf \
        "${pkgdir}/usr/lib/sysusers.d/pg-hardstorage.conf"
    install -Dm644 deploy/systemd/pg-hardstorage.tmpfiles.conf \
        "${pkgdir}/usr/lib/tmpfiles.d/pg-hardstorage.conf"

    # Config skeleton.
    install -d "${pkgdir}/etc/pg_hardstorage"
    if [[ -f deploy/config/pg_hardstorage.yaml.example ]]; then
        install -Dm644 deploy/config/pg_hardstorage.yaml.example \
            "${pkgdir}/etc/pg_hardstorage/pg_hardstorage.yaml.example"
    fi

    # Manpages — generated by docsgen during `make build`; ship
    # whichever ones exist at package time.
    if [[ -d man/man1 ]]; then
        for f in man/man1/*.1; do
            [[ -f "$f" ]] || continue
            install -Dm644 "$f" \
                "${pkgdir}/usr/share/man/man1/$(basename "$f")"
        done
    fi

    # Shell completions — bash + zsh.
    if [[ -f completions/bash/pg_hardstorage ]]; then
        install -Dm644 completions/bash/pg_hardstorage \
            "${pkgdir}/usr/share/bash-completion/completions/pg_hardstorage"
    fi
    if [[ -f completions/zsh/_pg_hardstorage ]]; then
        install -Dm644 completions/zsh/_pg_hardstorage \
            "${pkgdir}/usr/share/zsh/site-functions/_pg_hardstorage"
    fi

    # Docs.
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    if [[ -f CHANGELOG.md ]]; then
        install -Dm644 CHANGELOG.md "${pkgdir}/usr/share/doc/${pkgname}/CHANGELOG.md"
    fi
}
